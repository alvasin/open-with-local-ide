{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "types": ["chrome"],
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "~": ["./src"],
      "~/*": ["./src/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@native-protocol": ["../native-host/src/public-api/index.ts"]
    }
  }
}
